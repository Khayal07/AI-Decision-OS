# ─────────────────────────────────────────────────────────────
# AI Decision OS — environment variables (copy to .env.local)
# ─────────────────────────────────────────────────────────────

# --- Supabase (web app, public) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-side only, never exposed to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- AI service connection (used by the Next.js BFF) ---
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TOKEN=dev-internal-token

# --- LLM provider: OpenRouter (ai-service only) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Model routing defaults (free OpenRouter model ids) ---
MODEL_JUDGE=deepseek/deepseek-chat-v3-0324:free
MODEL_SUBAGENT=meta-llama/llama-3.3-70b-instruct:free

# --- Caching / rate limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Billing (Stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Observability ---
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
