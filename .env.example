# ─────────────────────────────────────────────────────────────
# AI Decision OS — environment variables (copy to .env.local)
# ─────────────────────────────────────────────────────────────

# --- Supabase (web app, public) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-side only, never exposed to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- AI service connection (used by the Next.js BFF) ---
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TOKEN=dev-internal-token

# --- LLM providers (ai-service only) ---
ANTHROPIC_API_KEY=
# Optional fallbacks / additional providers
OPENAI_API_KEY=
VOYAGE_API_KEY=

# --- Model routing defaults ---
MODEL_JUDGE=claude-opus-4-8
MODEL_SUBAGENT=claude-haiku-4-5-20251001
EMBEDDING_MODEL=voyage-3

# --- Caching / rate limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Billing (Stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Observability ---
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
